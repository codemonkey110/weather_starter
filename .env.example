# Optional data.gov.sg API key for higher rate limits.
# The app works without this for light local usage.
WEATHER_API_KEY=

# Stable local browser URL used by scripts/dev.mjs through Portless.
PORTLESS_PORT=1355
PORTLESS_HTTPS=0

# Optional path for the local SQLite database.
# DATABASE_PATH=backend/weather.db

# Host the Express server binds to.
# Set to 0.0.0.0 inside a devcontainer so VS Code port-forwarding can reach it.
# (devcontainer.json sets this automatically via remoteEnv.)
# HOST=127.0.0.1
